{
  "name": "fibi-project",
  "version": "1.0.0",
  "type": "module",
  "cleanUrls": true,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
