# ============================================
# .gitignore
# ============================================

# ==========================================
# ENVIRONMENT VARIABLES (САМОЕ ВАЖНОЕ!)
# ==========================================
.env
.env.local
.env.production
.env.*.local

# ==========================================
# NODE
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# IDE
# ==========================================
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# OS
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# LOGS
# ==========================================
logs/
*.log

# ==========================================
# DIST / BUILD
# ==========================================
dist/
build/
.vercel/

# ==========================================
# COVERAGE
# ==========================================
coverage/
.nyc_output/

# ==========================================
# TEMP
# ==========================================
tmp/
temp/
