# ============================================
# .env.example
# Версия: 2.0.0
# 
# ⚠️ НИКОГДА НЕ СОХРАНЯЙ РЕАЛЬНЫЕ ЗНАЧЕНИЯ В ЭТОТ ФАЙЛ!
# Скопируй в .env и заполни реальными данными.
# .env добавлен в .gitignore
# ============================================

# ==========================================
# SUPABASE
# ==========================================

# URL твоего Supabase проекта
# Пример: https://your-project-id.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Публичный ключ (используется в клиентских запросах)
# Найди в Supabase Dashboard → Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=your-anon-public-key-here

# Сервисный ключ (используется в cron-задачах и серверных операциях)
# ⚠️ НИКОГДА НЕ ИСПОЛЬЗУЙ НА КЛИЕНТЕ! Только в Edge-функциях!
# Найди в Supabase Dashboard → Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==========================================
# TELEGRAM
# ==========================================

# Токен Telegram бота (получи у @BotFather)
# Пример: 1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
BOT_TOKEN=your-bot-token-here

# ID Telegram канала для проверки подписки
# Пример: @my_channel или -1001234567890
CHANNEL_ID=@your_channel

# ==========================================
# SECURITY
# ==========================================

# Секрет для подписи device fingerprint (минимум 32 символа)
# Генерируй: openssl rand -hex 32
DEVICE_SECRET=your-device-secret-32-characters-min

# Секрет для cron-задач (должен совпадать с Authorization в cron-job.org)
# Генерируй: openssl rand -hex 32
CRON_SECRET=your-cron-secret-32-characters-min

# Включить логирование безопасности (true/false)
ENABLE_SECURITY_LOGS=true

# ==========================================
# AI KEYS (OpenRouter)
# ==========================================

# Ротация ключей OpenRouter (можно добавить до 10 штук)
# Получи ключи: https://openrouter.ai/keys
ROUTER_KEY0=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ROUTER_KEY1=sk-or-v1-yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
ROUTER_KEY2=sk-or-v1-zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz
ROUTER_KEY3=
ROUTER_KEY4=

# ==========================================
# MONITORING (опционально)
# ==========================================

# Sentry DSN для отслеживания ошибок (опционально)
# Получи: https://sentry.io → Settings → Projects → Client Keys (DSN)
SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/1234567
